# === LOLLMS CLIENT CONFIGURATION ===

# The LLM Binding to use
# Remote options: ollama, openai, mistral, groq, open_router, grok, perplexity, etc.
# Local options:  llama_cpp_server, vllm, transformers
LLM_BINDING_NAME=llama_cpp_server

# The specific model name to use
# - For remote: the model identifier (e.g., "gpt-4o", "gemma3:4b")
# - For local: the exact model filename (e.g., "mistralai_Ministral-3-3B-Instruct-2512-Q4_K_M.gguf")
MODEL_NAME=mistralai_Ministral-3-3B-Instruct-2512-Q4_K_M.gguf

# === REMOTE BINDING SETTINGS ===

# The host address of the remote binding server (used by ollama, openai, etc.)
# Leave empty for local bindings like llama_cpp_server
HOST_ADDRESS=http://localhost:11434

# SSL Verification
# Set to 'true' to verify SSL certificates (recommended for production)
# Set to 'false' to bypass SSL verification (for local self-signed certs)
VERIFY_SSL=false

# === GATED SERVICE AUTHENTICATION (Optional) ===
# If using a gated cloud service (e.g., openai, mistral, groq, open_router),
# uncomment the following line and paste your API key here.
# The script will automatically inject this into the binding configuration.
# API_KEY=sk-your-api-key-here

# === LOCAL BINDING SETTINGS (llama_cpp_server / vllm) ===

# Path to the local directory containing your downloaded .gguf models
# MODELS_PATH=/path/to/models/folder

# Path to the llama.cpp server binaries (if using llama_cpp_server)
# BINARIES_PATH=/path/to/llama_cpp/binaries

# Context window size (in tokens) for local models
CONTEXT_SIZE=8192

# Number of layers to offload to GPU (-1 for all, 0 for CPU only)
N_GPU_LAYERS=-1

# === DISCUSSION SETTINGS ===

# Enable verbose debug logging in the console
DEBUG=true
