# === LOLLMS CLIENT CONFIGURATION ===

# The LLM Binding to use (e.g., ollama, openai, llama_cpp_server, lollms)
LLM_BINDING_NAME=ollama

# The specific model name to use
MODEL_NAME=gemma3:4b

# The host address of the binding server
HOST_ADDRESS=http://localhost:11434

# SSL Verification
# Set to 'true' to verify SSL certificates (recommended for production)
# Set to 'false' to bypass SSL verification (for local self-signed certs)
VERIFY_SSL=false

# === GATED SERVICE AUTHENTICATION (Optional) ===
# If using a gated cloud service (e.g., openai, mistral, groq, open_router),
# uncomment the following line and paste your API key here.
# The test script will automatically inject this into the binding configuration.
# API_KEY=sk-your-api-key-here


# === DISCUSSION SETTINGS ===

# Enable verbose debug logging in the console
DEBUG=true
